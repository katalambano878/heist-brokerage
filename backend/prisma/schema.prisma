generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum PropertyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  VIEWING
  NEGOTIATING
  WON
  LOST
}

enum LeadSource {
  CONTACT_FORM
  LEAD_MODAL
  PROPERTY
  WHATSAPP
  OTHER
}

enum ApplicationStatus {
  NEW
  REVIEWING
  SHORTLISTED
  INTERVIEW
  HIRED
  REJECTED
}

model AdminUser {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String?
  role          Role           @default(STAFF)
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  leadNotes     LeadNote[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model Property {
  id          String          @id @default(uuid())
  title       String
  slug        String          @unique
  location    String
  /// Display price, e.g. "GHS 8,950,000"
  price       String
  beds        Int             @default(0)
  baths       Int             @default(0)
  /// Display square footage, e.g. "6,200"
  sqft        String          @default("")
  tag         String          @default("")
  type        String          @default("")
  /// Listing category used for site filtering: "sale" | "rent" | "land"
  category    String          @default("sale")
  /// Region used for site search filtering, e.g. "East Legon Hills"
  region      String          @default("")
  description String          @default("")
  status      PropertyStatus  @default(DRAFT)
  featured    Boolean         @default(false)
  sortOrder   Int             @default(0)
  images      PropertyImage[]
  leads       Lead[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  alt        String   @default("")
  sortOrder  Int      @default(0)
}

model TeamMember {
  id        String   @id @default(uuid())
  name      String
  title     String
  focus     String   @default("")
  imageUrl  String   @default("")
  featured  Boolean  @default(false)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String   @default("")
  imageUrl    String   @default("")
  imageAlt    String   @default("")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(uuid())
  quote     String
  name      String
  role      String   @default("")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Rich development/cluster listings (e.g. Devtraco Woodlands).
/// Structured arrays are stored as JSON to keep editing flexible:
/// overview: string[], facts: {label,value}[], highlights: string[],
/// typologies: {name,beds,storeys,blurb,imageSrc}[],
/// amenities: string[], connectivity: {place,time}[],
/// gallery: {src,alt}[], sitemap: {src,alt} | null
model ExclusiveListing {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  developer     String   @default("")
  category      String   @default("")
  partOf        String?
  location      String   @default("")
  status        String   @default("Selling Now")
  tagline       String   @default("")
  summary       String   @default("")
  heroImage     String   @default("")
  cardImage     String   @default("")
  overview      Json     @default("[]")
  facts         Json     @default("[]")
  highlights    Json     @default("[]")
  typologies    Json     @default("[]")
  amenities     Json     @default("[]")
  connectivity  Json     @default("[]")
  gallery       Json     @default("[]")
  sitemap       Json?
  startingPrice String?
  paymentNote   String?
  brochureUrl   String   @default("")
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Lead {
  id         String     @id @default(uuid())
  name       String
  email      String     @default("")
  phone      String     @default("")
  message    String     @default("")
  source     LeadSource @default(CONTACT_FORM)
  status     LeadStatus @default(NEW)
  propertyId String?
  property   Property?  @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  notes      LeadNote[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model LeadNote {
  id        String     @id @default(uuid())
  leadId    String
  lead      Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String?
  author    AdminUser? @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime   @default(now())
}

model Application {
  id         String            @id @default(uuid())
  fullName   String
  email      String            @default("")
  phone      String            @default("")
  position   String            @default("")
  experience String            @default("")
  portfolio  String            @default("")
  message    String            @default("")
  status     ApplicationStatus @default(NEW)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model SiteSettings {
  id           String   @id @default("default")
  phones       Json     @default("[]")
  whatsapp     String   @default("")
  addressLine1 String   @default("")
  addressLine2 String   @default("")
  city         String   @default("")
  email        String   @default("")
  instagram    String   @default("")
  tiktok       String   @default("")
  facebook     String   @default("")
  /// Image for the homepage "Heist Mentality" / About preview section
  aboutImage   String   @default("")
  /// Homepage stats: {label, target, suffix}[]
  trustStats   Json     @default("[]")
  updatedAt    DateTime @updatedAt
}
