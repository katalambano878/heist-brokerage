# PostgreSQL (Docker: see docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/heist_brokerage?schema=public"

# JWT — must be ≥32 characters (openssl rand -hex 32)
JWT_ACCESS_SECRET="dev-only-access-secret-replace-in-production-32chars-min"
JWT_REFRESH_SECRET="dev-only-refresh-secret-replace-in-production-32chars-min"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# CORS — comma-separated origins (no trailing slashes)
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Server
PORT=4000
NODE_ENV=development

# Public base URL of this API (used in uploaded-image URLs)
PUBLIC_API_URL="http://localhost:4000"

# Where uploaded images are written (defaults to ./uploads)
# UPLOAD_DIR=/data/uploads

# Seed admin credentials (used by `npm run db:seed`)
SEED_ADMIN_EMAIL="admin@heistbrokerage.com"
SEED_ADMIN_PASSWORD="HeistAdmin#2026"
